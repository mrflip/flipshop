{
  "$schema":  "https://json.schemastore.org/tsconfig",
  "extends":  "./tsconfig-base.json",
  "include":  ["src/**/*.ts", "tests/**/*.ts"],
  "exclude":  ["node_modules", "built", "**/built/**/*", "**/.yarn/**/*"],

  "references": [
    { "path":               "./tsconfig.json"               }
  ],

  "compilerOptions": {
    "rootDir":                            ".",
    "isolatedModules":                    true,
    "allowSyntheticDefaultImports":       true,          /* Allow 'import x from y' when a module doesn't have a default export. */
    "resolvePackageJsonImports":          true,          /* Use the package.json 'imports' field when resolving imports. */
    "resolvePackageJsonExports":          true,          /* Use the package.json 'exports' field when resolving package imports. */
    "noEmit":                             true,
    "paths": {  /* make the tests work with the monorepo, so local package imports work */
      "@flipshop/flipshop":               ["src/index.ts"]
    },
    //     /* specify one, you have to specify all; testGlobals makes ts-jest work with jest+chai mix */
    //     "types":                              ["./testGlobals.d.ts", "jest", "chai", "node", "sinon", "snowball-stemmers"],
    //     // true to see super-long error messages
    "noErrorTruncation":                  false
  }
}

//     "composite":                          false,   // and not referenced by others
