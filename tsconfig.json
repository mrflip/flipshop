{
  "$schema":                "https://json.schemastore.org/tsconfig",
  // "extends":             "./tsconfig-base.json",
  "files":                  [],
  "include":                [],
  // "include":                            ["src/**/*.ts", "db/**/*.ts", "src/**/*.js"],
  // "references": [
  //   { "path":            "./meta/tsconfig.json" },
  //   { "path":            "./mungers/wiktionary/tsconfig.json" },
  // ],
  "compilerOptions": {
    "tsBuildInfoFile":                    "./.tsbuildinfo-flipshop-internals",
    "outDir":                             "./built/internals",  /* Specify the path to .tsbuildinfo incremental compilation file. */
    "rootDir":                            "./src",
    "composite":                          true,
    //
    "noImplicitAny":                      false,
    "noImplicitOverride":                 false,
    //
    "noErrorTruncation":                  false  // true to see super-long error messages
  }
}
