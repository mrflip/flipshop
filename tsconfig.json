{
  "$schema":            "https://json.schemastore.org/tsconfig",
  "display":            "Node 23",
  "extends":            "./tsconfig-base.json",
  "include":            ["src/**/*.ts", "src/**/*.js", "src/**/*.json"],
  "exclude":            ["node_modules", "built", "**/built/**/*", "built/**/*", "**/.yarn/**/*"],
  //
  "references":  [
  ],

  "compilerOptions": {
    "tsBuildInfoFile":                    "./.tsbuildinfo-flipshop",
    "outDir":                             "./built",
    "rootDir":                            "./src",
    "composite":                          true,
    //
    "noImplicitAny":                      false,
    "noImplicitOverride":                 false,
    //
    "noErrorTruncation":                  false  // true to see super-long error messages
    //
  }
}
