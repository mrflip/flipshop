{
  "name": "@flipshop/flipshop",
  "version": "1.0.0",
  "description": "Flipshop: a collection of tools for working with fasteners",
  "private": true,
  "workspaces": [
    "src/*"
  ],
  "scripts": {
    "shipme": "         echo 'I am not a package, but I am still awesome'",
    "build": "          yarn ts:build",
    "ship:it": "        ./scripts/shipit.sh",
    "ver:show": "       ./scripts/version-show.sh",
    "ver:clobber": "    ./scripts/version-clobber.sh",
    "ver:extract": "    ./scripts/version-extract.sh",
    "ver:bump": "       yarn workspace internals version patch",
    "ts:clean": "       ./scripts/ts-clean.sh",
    "ts:build": "       yarn tsc   --build --verbose",
    "ts:watch": "       yarn ts:build --watch",
    "_1": " echo .",
    "test": "           yarn node --experimental-vm-modules                      $(yarn bin jest)",
    "test:plain": "     yarn node --experimental-vm-modules --enable-source-maps $(yarn bin jest)",
    "test:coverage": "  yarn node --experimental-vm-modules --enable-source-maps $(yarn bin jest) --coverage",
    "test:watch": "     yarn node --experimental-vm-modules --enable-source-maps $(yarn bin jest) --watch",
    "twitch": "         yarn node --experimental-vm-modules --enable-source-maps $(yarn bin jest) --watch",
    "_2": " echo .",
    "git:yarnicles": "  git ci -m 'chore: pkgs + yarnicles' .yarn yarn.lock .yarnrc.yml package.json",
    "_z": "echo ."
  },
  "dependencies": {
    "@freeword/meta": "file:../freeword/meta",
    "esm-seedrandom": "3.0.5-esm.2",
    "eta": "^4.5.1",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "papaparse": "^5.5.3",
    "sprintf-js": "^1.1.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@jest/types": "^30.3.0",
    "@types/chai": "^5.2.3",
    "@types/chai-arrays": "^2.0.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5",
    "@types/seedrandom": "^3.0.8",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@types/snowball-stemmers": "^0.6.2",
    "@types/sprintf-js": "^1.1.4",
    "chai": "^5.3.3",
    "jest": "^30.3.0",
    "jest-util": "^30.3.0",
    "seedrandom": "^3.0.5",
    "sinon": "^21.0.2",
    "sinon-chai": "^4.0.1",
    "ts-jest": "^29.4.6",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "workshop",
    "fasteners"
  ],
  "author": "flip kromer and the flipshop team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrflip/flipshop"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "README.md"
  ],
  "packageManager": "yarn@4.13.0"
}
